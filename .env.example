# =============================================================
# SUPABASE — Obrigatório
# Crie seu projeto em https://supabase.com (gratuito)
# =============================================================
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_ANON_KEY

# =============================================================
# STRIPE — Pagamentos (opcional, configurar no Admin Mestre)
# https://dashboard.stripe.com/apikeys
# =============================================================
VITE_STRIPE_PUBLIC_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================
# MERCADO PAGO — Pagamentos (opcional, configurar no Admin Mestre)
# https://www.mercadopago.com.br/developers/panel/app
# =============================================================
VITE_MP_PUBLIC_KEY=APP_USR-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================
# DOMÍNIO BASE DA PLATAFORMA
# Usado para gerar URLs dos consultores: seudominio.com/nomedaconsultora
# =============================================================
VITE_BASE_URL=https://seudominio.com.br

# =============================================================
# ADMIN MESTRE — E-mail do super admin
# =============================================================
VITE_MASTER_ADMIN_EMAIL=admin@seudominio.com.br
